<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="Content-Language" content="en">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="Complete dispatch solution for first responders, business and industry">
    <meta name="author" content="SparkOps Core">
    <meta name="keywords" content="dispatch, cad, automated, computer, response, fire, department, volunteer, brigade, cert, search and rescue, sar, ems, emt, fire fighter, firefighter, logistics, personnel, apparatus, unit, security, disaster">
    <link rel="shortcut icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <meta http-equiv="Access-Control-Allow-Origin" content="*" />
    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_StylePartial")

    <!-- Add local styles, mostly for plugins css file -->
    @if (IsSectionDefined("Styles"))
    {
        @RenderSection("Styles", required: false)
    }

    @if (!String.IsNullOrWhiteSpace(Resgrid.Config.TelemetryConfig.CountlyUrl) && !String.IsNullOrWhiteSpace(Resgrid.Config.TelemetryConfig.CountlyWebKey))
    {
        <script type='text/javascript' src="~/lib/countly-sdk-web/lib/countly.min.js"></script>
        <script type='text/javascript'>
            if (window.Countly && typeof window.Countly.init === 'function') {
                window.Countly.init({
                    app_key: "@Resgrid.Config.TelemetryConfig.CountlyWebKey",
                    url: "@Resgrid.Config.TelemetryConfig.CountlyUrl",
                    debug: false,
                    ignore_referrers: [],
                    track_sessions: true,
                    track_pageview: true,
                    track_links: true,
                    track_forms: true,
                    track_errors: true,
                    require_consent: false,
                    force_post: true,
                    ignore_bots: true
                });
            }
        </script>
    }
</head>
<body id="page-top" class="landing-page">

    @RenderBody()

    <section id="contact" class="gray-section contact">
        <div class="container">
            <div class="row m-b-lg">
                <div class="col-lg-12 text-center">
                    <div class="navy-line"></div>
                </div>
            </div>
            <div class="row m-b-lg">
                <div class="col-lg-2 col-lg-offset-2">
                    <address>
                        <strong><span class="navy">SparkOps Core</span></strong><br />
                    </address>
                </div>
                <div class="col-lg-4">
                    <p class="text-color text-center">
                        <ul class="list-group text-center" style="list-style: none;">
                            <li><a asp-controller="Home" asp-action="OpenSource" asp-area="">Open Source</a></li>
                            <li><a asp-controller="Home" asp-action="Apps" asp-area="">Mobile Apps</a></li>
                        </ul>
                    </p>
                </div>
                <div class="col-lg-4">
                    <address>
                        <strong><span class="navy">Contact Us</span></strong><br />
                        <a asp-controller="Home" asp-action="Contact" asp-area="">Contact Our Team</a><br />
                    </address>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-8 col-lg-offset-2 text-center m-t-lg m-b-lg">
                    <p><strong>SparkOps Core</strong> &mdash; Based on <a href="https://github.com/Resgrid/Core" target="_blank">Resgrid</a> (Apache 2.0)<br /> <a asp-controller="Public" asp-action="Privacy">Privacy Policy</a> | <a asp-controller="Public" asp-action="Terms">Terms of Service</a></p>
                </div>
            </div>
        </div>
    </section>

    @await Html.PartialAsync("_ScriptsPartial")

    @if (IsSectionDefined("Scripts"))
    {
        @RenderSection("Scripts", required: false)
    }
</body>
</html>
